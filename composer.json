{
    "name": "runasroot/module-seeder",
    "description": "Laravel-style database seeding for Magento 2",
    "type": "magento2-module",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "magento/framework": "*",
        "magento/module-bundle": "*",
        "magento/module-catalog": "*",
        "magento/module-catalog-inventory": "*",
        "magento/module-checkout": "*",
        "magento/module-cms": "*",
        "magento/module-configurable-product": "*",
        "magento/module-customer": "*",
        "magento/module-downloadable": "*",
        "magento/module-grouped-product": "*",
        "magento/module-quote": "*",
        "magento/module-sales": "*",
        "fakerphp/faker": "^1.23",
        "symfony/yaml": "^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/console": "^6.0 || ^7.0",
        "phpstan/phpstan": "^1.11",
        "magento/magento-coding-standard": "*",
        "squizlabs/php_codesniffer": "^3.10",
        "psr/log": "^3.0"
    },
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "RunAsRoot\\Seeder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RunAsRoot\\Seeder\\Test\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs --standard=Magento2 --report=full src",
        "phpcbf": "phpcbf --standard=Magento2 src",
        "check": ["@phpcs", "@phpstan", "phpunit"]
    },
    "repositories": {
        "magento-stubs": {
            "type": "package",
            "package": [
                {"name": "magento/framework", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-bundle", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-catalog", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-catalog-inventory", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-checkout", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-cms", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-configurable-product", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-customer", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-downloadable", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-grouped-product", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-quote", "version": "999.999.999", "type": "metapackage"},
                {"name": "magento/module-sales", "version": "999.999.999", "type": "metapackage"}
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
