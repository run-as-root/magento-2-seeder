parameters:
    level: 5
    paths:
        - src
    excludePaths:
        - Test/*
    ignoreErrors:
        - '#Class Magento\\[\\A-Za-z]+ not found#'
        - '#Call to method [a-zA-Z]+\(\) on an unknown class Magento\\#'
        - '#Access to property \$[a-zA-Z]+ on an unknown class Magento\\#'
        - '#Access to constant [A-Z_]+ on an unknown class Magento\\#'
        - '#Instantiated class Magento\\[\\A-Za-z]+ not found#'
        - '#Caught class Magento\\[\\A-Za-z]+ not found#'
        - '#Parameter .* of method .* has invalid type Magento\\#'
        - '#Return type .* of method .* has invalid type Magento\\#'
        - '#Method .* has invalid return type Magento\\#'
        - '#Property .* has unknown class Magento\\[\\A-Za-z]+ as its type#'
        - '#Zend_Db_Expr#'
        # Mocked run() results in tests may omit the 'failed' key; production code uses ?? 0
        - '#Offset .failed. on array\{type: string, success: .*, count: int, failed: int, error: string\|null\} on left side of \?\? always exists and is not nullable#'
    reportUnmatchedIgnoredErrors: false
